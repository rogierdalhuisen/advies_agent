# Example ingestion configuration
# Copy this to ingestion.yaml and modify as needed

embedding:
  provider: openai  # Options: openai, gemini, openrouter
  model_name: text-embedding-3-large
  dimension: 3072
  batch_size: 100

  # For OpenRouter (if provider: openrouter)
  # openrouter_base_url: https://openrouter.ai/api/v1

chunking:
  strategy: hybrid  # Options: hierarchical, hybrid
  max_chunk_size: 1000  # Maximum characters per chunk
  chunk_overlap: 100    # Overlap between chunks
  size_threshold: 800   # Split chunks larger than this
  strip_headers: false  # Keep headers in chunk content

collection:
  name: insurance_documents
  use_sparse: true  # Enable hybrid retrieval (dense + sparse)
  sparse_model: Qdrant/bm25
  dense_vector_name: dense
  sparse_vector_name: sparse

# Pipeline settings
documents_dir: data/documents
chunks_output_dir: data/documents/chunks
enable_deduplication: true
save_chunks_to_disk: true

# === Alternative Configurations ===

# Smaller/faster embeddings (lower cost):
# embedding:
#   provider: openai
#   model_name: text-embedding-3-small
#   dimension: 1536

# Google Gemini embeddings:
# embedding:
#   provider: gemini
#   model_name: models/embedding-001
#   dimension: 768

# Pure hierarchical chunking (no size limit):
# chunking:
#   strategy: hierarchical
